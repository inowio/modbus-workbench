{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inowio-Modbus-Toolbox",
  "version": "0.2.0",
  "identifier": "in.inowio.modbus.toolbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Inowio - Modbus Toolbox",
        "width": 1280,
        "height": 720,
        "maximized": true,
        "theme": "Dark",
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Inowio Technologies LLP",
    "longDescription": "Modbus Toolbox",
    "homepage": "https://inowio.in",
    "publisher": "Inowio Technologies LLP",
    "shortDescription": "Configure, test, monitor the Modbus devices.",
    "license": "MIT",
    "category": "Utility",
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "nsis": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "offlineInstaller"
      },
      "wix": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/inowio/modbus-toolbox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBCMERGRTU0MTJERURFQTUKUldTbDN0NFNWUDROQyt0dmdoVlVOSS9udGlhbmxnbG5UdkVSeGhaQWdGemN6MUxpZm1ZdWVhT1kK"
    }
  }
}
